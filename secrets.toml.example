# Example Streamlit secrets file for the Lead Scraper.
#
# Copy this to `.streamlit/secrets.toml` (which is git-ignored) for local runs.
# In deployment, the container materializes this same file at startup from the
# base64-encoded SECRETS_TOML_B64 env var — see the deployment brief / RUNBOOK.
#
# Top-level keys mirror .env. The [auth.users.*] table below has no .env
# equivalent — it is the per-user login table, read directly by config.py.

GOOGLE_PLACES_API_KEY = "paste_your_google_key_here"
ANTHROPIC_API_KEY = "paste_your_anthropic_key_here"

# REQUIRED. A long random string; rotate per client instance. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
COOKIE_KEY = "paste_a_long_random_string_here"

# Optional. Defaults: COOKIE_NAME="lead_scraper_auth", CLIENT_NAME="Lead Scraper".
# Give each client a unique COOKIE_NAME so cookies never collide across instances.
COOKIE_NAME = "lead_scraper_auth"
CLIENT_NAME = "Acme Corp Lead Scraper"

# One [auth.users.<username>] block per login. The password value is a bcrypt
# hash from gen_password_hash.py — never a plaintext password. `email` is optional.
[auth.users.alice]
name = "Alice Example"
password = "$2b$12$REPLACE_WITH_A_REAL_BCRYPT_HASH_FROM_gen_password_hash"
email = "alice@example.com"
