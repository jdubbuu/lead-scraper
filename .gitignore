.env
*.xlsx
*.db
__pycache__/
*.pyc
.venv/
venv/

# Secrets — never commit. The example files (*.example) are safe to track.
secrets.toml
.streamlit/secrets.toml
.streamlit/

# Backups (client data) — never commit.
backups/

# Deployment operator state and per-client instance configs (client-specific).
# The committed template deploy/instances/example.env is the only exception.
deploy/state/
deploy/instances/*.env
!deploy/instances/example.env

# Local tooling config
.claude/

# Internal docs / learning notes — keep out of the public repo
*.docx
*.pdf
Product info/
understanding_claude_code.md
understanding_scraper_code.md
client_demo_script.md
make_summary_pdf.py
