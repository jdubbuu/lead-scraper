# Per-instance rollout config. Copy to deploy/instances/<instance>.env and fill
# in. These values are client-specific but NOT secret (no API keys, no logins).
# Real <instance>.env files are git-ignored; only this example is committed.
#
# The instance name is the filename without .env, e.g. this file would be
# referenced as `example`:  deploy/rollout.sh deploy v1.0.0 example

# Render service id for this client's instance (from the Render dashboard/API).
RENDER_SERVICE_ID=srv-xxxxxxxxxxxxxxxxxxxx

# Public base URL of the instance (no trailing path). rollout.sh appends
# /_stcore/health for its post-deploy health check.
HEALTHCHECK_URL=https://example-leads.onrender.com
