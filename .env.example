GOOGLE_PLACES_API_KEY=paste_your_google_key_here
ANTHROPIC_API_KEY=paste_your_anthropic_key_here

# --- Auth / login ---------------------------------------------------------
# COOKIE_KEY is REQUIRED — the app refuses to start without it. Use a long,
# random string (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
COOKIE_KEY=paste_a_long_random_string_here
# Optional: a per-client cookie name and display name. Sensible defaults apply.
COOKIE_NAME=lead_scraper_auth
CLIENT_NAME=Lead Scraper

# NOTE: user logins ([auth.users.*]) are NOT set here — they live in
# .streamlit/secrets.toml (see secrets.toml.example).
