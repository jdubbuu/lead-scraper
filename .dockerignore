# Keep the build context minimal and free of anything sensitive or per-client.
# Secrets and databases must never enter the image.

# VCS / tooling
.git
.gitignore
.claude/

# Secrets & local config (injected at runtime instead)
.env
.env.example
.streamlit/
secrets.toml
secrets.toml.example

# Databases & exports (data lives on the mounted volume, not in the image)
*.db
*.xlsx
backups/

# Python caches / virtualenvs
__pycache__/
*.pyc
.venv/
venv/

# Deployment/operator material not needed at runtime
deploy/
RUNBOOK.md
BRIEF_deployment_and_updates.md

# Internal docs / notes
*.md
*.docx
*.pdf
Product info/
Analyses/
